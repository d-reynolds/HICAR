# Copy to runner.env (gitignored) and fill in. Do NOT commit secrets.
REPO_URL=https://github.com/d-reynolds/HICAR

# Preferred: a PAT with repo administration scope so the runner can fetch a
# fresh registration token on every restart (registration tokens expire ~1h).
GH_PAT=

# Alternative to GH_PAT: a one-shot registration token from
#   Settings > Actions > Runners > New self-hosted runner.
# RUNNER_TOKEN=

# Optional overrides:
# RUNNER_NAME=hicar-gpu-box1
# RUNNER_LABELS=self-hosted,gpu,nvhpc
