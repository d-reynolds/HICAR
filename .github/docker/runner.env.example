# Copy to runner.env (gitignored) and fill in. Do NOT commit secrets.
#
# REPO_URL selects the runner scope (auto-detected by entrypoint.sh):
#   https://github.com/HICAR-Model         -> org-level runner, serves every repo (RECOMMENDED)
#   https://github.com/HICAR-Model/HICAR   -> single-repo runner
REPO_URL=https://github.com/HICAR-Model

# Fine-grained PAT used to mint a fresh registration token on each restart
# (registration tokens expire ~1h, so the ephemeral loop needs a renewable credential).
# Grant the LEAST privilege for the scope chosen above — nothing more:
#   org-level  -> Organization permissions: "Self-hosted runners" = Read and write
#   repo-level -> Repository permissions:   "Administration"       = Read and write
GH_PAT=

# Alternative to GH_PAT: a one-shot registration token from
#   Settings > Actions > Runners > New self-hosted runner.
# RUNNER_TOKEN=

# Optional overrides:
# RUNNER_NAME=hicar-gpu-box1
# RUNNER_LABELS=self-hosted,gpu,nvhpc
